{
  "name": "@corner-case/keeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TxLINE keeper: managed auth, typed API client, match recorder and replay harness for Corner Case",
  "scripts": {
    "record": "tsx src/record.ts",
    "replay": "tsx src/replay.ts",
    "smoke": "tsx src/record.ts --smoke && tsx src/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
